    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.98.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.469.0",
    "next": "15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/leaflet": "^1.9.21",
